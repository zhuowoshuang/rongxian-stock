# ==================== 数据库 ====================
# SQLite（本地开发，无需安装数据库）
DATABASE_URL=sqlite:///./stock_agent.db

# PostgreSQL（生产环境推荐）
# DATABASE_URL=postgresql://postgres:postgres@db:5432/stock_agent

# ==================== 安全 ====================
# JWT 密钥（生产环境必须修改！可通过 python -c "import secrets; print(secrets.token_hex(32))" 生成）
JWT_SECRET_KEY=

# ==================== 数据源 ====================
# 是否使用 Mock 数据（false = 使用真实数据源）
MOCK_DATA=true

# ==================== LLM API（可选，用于 AI 分析功能）====================
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=deepseek-v4-pro

# ==================== 通知推送（可选）====================
# QQ 邮箱 SMTP
EMAIL_SMTP_HOST=smtp.qq.com
EMAIL_SMTP_PORT=465
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECIPIENT=

# 飞书 Webhook
FEISHU_WEBHOOK=
FEISHU_ENABLED=false
